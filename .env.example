# =============================================================================
# Breach Tower -- Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================


# -- Database -----------------------------------------------------------------
DB_PASSWORD=changeme
DATABASE_URL=postgresql://admin:changeme@localhost:5432/breachtower


# -- Auth ---------------------------------------------------------------------
# Generate JWT_SECRET with:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_minimum_64_chars
VAULT_PASSWORD=CHANGE_ME_use_a_strong_random_password


# -- Have I Been Pwned (haveibeenpwned.com/API) -------------------------------
HIBP_API_KEY=your_hibp_key_here


# -- BreachDirectory (breachdirectory.org) ------------------------------------
BREACH_DIRECTORY_KEY=your_rapidapi_key_here


# -- LeakCheck (leakcheck.io) -------------------------------------------------
LEAKCHECK_API_KEY=your_leakcheck_key_here


# -- IntelligenceX (intelx.io) ------------------------------------------------
INTELX_API_KEY=your_intelx_key_here


# -- Leak-Lookup (leak-lookup.com) --------------------------------------------
LEAKLOOKUP_API_KEY=your_leaklookup_key_here


# -- Telegram (my.telegram.org) -----------------------------------------------
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash


# -- SMTP (Gmail App Password recommended) ------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=alerts@yourcompany.com


# -- Slack Webhook (api.slack.com/apps) ---------------------------------------
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL


# -- Pastebin -----------------------------------------------------------------
PASTEBIN_API_KEY=your_pastebin_api_key
PASTEBIN_API_USER_KEY=your_pastebin_user_key


# -- Scan config --------------------------------------------------------------
SCAN_INTERVAL_HOURS=6
DISABLED_MONITORS=breach


# -- CORS (comma-separated allowed origins) -----------------------------------
ALLOWED_ORIGINS=http://localhost:3000


# -- Microsoft SSO (optional -- leave blank to disable SSO button) ------------
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
