<Application x:Class="BreachTowerInstaller.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>

    <!-- ── Colour palette ─────────────────────────────────── -->
    <SolidColorBrush x:Key="BgBrush"        Color="#0d0d0d"/>
    <SolidColorBrush x:Key="PanelBrush"     Color="#141414"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="#2a2a2a"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="#e53935"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#7f1d1d"/>
    <SolidColorBrush x:Key="TextBrush"      Color="#f0f0f0"/>
    <SolidColorBrush x:Key="DimBrush"       Color="#6b7280"/>
    <SolidColorBrush x:Key="SuccessBrush"   Color="#22c55e"/>
    <SolidColorBrush x:Key="WarnBrush"      Color="#f59e0b"/>
    <SolidColorBrush x:Key="ErrorBrush"     Color="#ef4444"/>
    <SolidColorBrush x:Key="InfoBrush"      Color="#38bdf8"/>
    <SolidColorBrush x:Key="InputBgBrush"   Color="#1e1e1e"/>

    <!-- ── Base button style ──────────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="FontFamily"   Value="Segoe UI"/>
      <Setter Property="FontSize"     Value="13"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Padding"      Value="24,10"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#ef5350"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#c62828"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background" Value="#3a3a3a"/>
                <Setter Property="Foreground" Value="#555"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#2a2a2a"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}"
                    BorderBrush="#444" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#3a3a3a"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── TextBox style ──────────────────────────────────── -->
    <Style x:Key="DarkInput" TargetType="TextBox">
      <Setter Property="Background"       Value="{StaticResource InputBgBrush}"/>
      <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush"      Value="#3a3a3a"/>
      <Setter Property="BorderThickness"  Value="1"/>
      <Setter Property="Padding"          Value="10,7"/>
      <Setter Property="FontFamily"       Value="Segoe UI"/>
      <Setter Property="FontSize"         Value="13"/>
      <Setter Property="CaretBrush"       Value="{StaticResource AccentBrush}"/>
      <Setter Property="SelectionBrush"   Value="{StaticResource AccentDimBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── PasswordBox style ──────────────────────────────── -->
    <Style x:Key="DarkPassword" TargetType="PasswordBox">
      <Setter Property="Background"      Value="{StaticResource InputBgBrush}"/>
      <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
      <Setter Property="BorderBrush"     Value="#3a3a3a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding"         Value="10,7"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
    </Style>

  </Application.Resources>
</Application>
